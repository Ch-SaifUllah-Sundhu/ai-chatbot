# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file and rename it to .env, then fill in your real values.
# NEVER commit the actual .env file to GitHub!

# Your Google Gemini API Key
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# A long, random secret string used to sign JWT tokens
# You can generate one by running: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/chatbot?retryWrites=true&w=majority

# The port the backend server runs on (default: 5000)
PORT=5000

# (Optional) For production: restrict CORS to your deployed frontend URL
# FRONTEND_URL=https://your-app.vercel.app
